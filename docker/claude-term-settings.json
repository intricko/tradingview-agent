{
  "env": {
    "ANTHROPIC_API_KEY": "sk-whatever",
    "ANTHROPIC_BASE_URL": "http://localhost:7352",
    "ANTHROPIC_MODEL": "claude-sonnet-4-5"
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/mnemon/prime.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/mnemon/stop.sh"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/mnemon/user_prompt.sh"
          }
        ]
      }
    ]
  },
  "theme": "dark"
}
